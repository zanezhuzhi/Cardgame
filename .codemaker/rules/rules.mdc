## 7. Vue 组件规范

### 7.1 组件结构
```vue
<template>
  <!-- 模板内容 -->
</template>

<script setup lang="ts">
// 导入
import { ref, computed, watch, onMounted } from 'vue';
import type { PlayerState, CardInstance } from '@shared/types';

// Props
const props = defineProps<{
  player: PlayerState;
}>();

// Emits
