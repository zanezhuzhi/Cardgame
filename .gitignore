# `tsc` may emit JS / d.ts into source dirs if misconfigured.
# Keep sources tracked (e.g. shared/types/*.ts), ignore emitted outputs.
shared/types/**/*.js
shared/types/**/*.js.map
shared/types/**/*.d.ts.map
shared/game/**/*.js
shared/game/**/*.js.map


